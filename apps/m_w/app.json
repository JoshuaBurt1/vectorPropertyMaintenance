{
  "expo": {
    "name": "VectorPM-Worker",
    "slug": "vector-pm-worker",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "newArchEnabled": true,
    "plugins": [
      "expo-system-ui",
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Allow VectorPM to show your location on the route map."
        }
      ]
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "package": "com.jburt4.worker",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "RECORD_AUDIO"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.jburt4.worker",
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Allow VectorPM to show your location on the route map.",
        "NSMicrophoneUsageDescription": "Allow VectorPM to access the microphone."
      }
    }
  }
}