{
  "expo": {
    "name": "VectorPM-Worker",
    "slug": "vector-pm-worker",
    "version": "1.0.0",
    "newArchEnabled": true,
    "plugins": [
      "expo-system-ui",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow VectorPM to access your camera to take job site photos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Allow VectorPM to show your location on the route map."
        }
      ]
    ],
    "android": {
      "package": "com.jburt4.worker",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "RECORD_AUDIO"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY_HERE"
        }
      }
    }
  }
}